# Google Gemini API key — get a free one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional overrides (defaults shown)
GEMINI_MODEL=gemini-2.5-flash
PORT=4000
BATCH_SIZE=20
BATCH_CONCURRENCY=3
AI_MAX_ATTEMPTS=3
MAX_FILE_SIZE_MB=5
MAX_ROWS=2000
ALLOWED_ORIGIN=*
